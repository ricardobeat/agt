#!/bin/zsh
set -euo pipefail

AGT_DEFAULT_IMAGE="agt-sandbox"
AGT_DIR="$(cd "$(dirname "$(readlink -f "$0" || realpath "$0")")" && pwd)"

red()    { printf "\033[31m%s\033[0m\n" "$1" >&2; }
green()  { printf "\033[32m%s\033[0m\n" "$1"; }
yellow() { printf "\033[33m%s\033[0m\n" "$1"; }
bold()   { printf "\033[1m%s\033[0m\n" "$1"; }

# --- config ---

# Reads a key from a TOML file (flat keys only, e.g. "execution.mode")
toml_get() {
  local file="$1" key="$2"
  local section="" field=""
  section="${key%%.*}"
  field="${key#*.}"
  awk -v sec="$section" -v key="$field" '
    /^\[/ { in_sec = ($0 == "[" sec "]"); next }
    in_sec && match($0, "^" key "[ \t]*=[ \t]*") {
      val = substr($0, RSTART + RLENGTH)
      gsub(/^["'\''"]|["'\''"]$/, "", val)
      print val
      exit
    }
  ' "$file"
}

load_config() {
  AGT_MODE="container"

  local config_file=""
  if [[ -f "./agt.toml" ]]; then
    config_file="./agt.toml"
  elif [[ -f "$HOME/.config/agt/config.toml" ]]; then
    config_file="$HOME/.config/agt/config.toml"
  fi

  if [[ -n "$config_file" ]]; then
    local mode
    mode="$(toml_get "$config_file" "execution.mode")"
    if [[ -n "$mode" ]]; then
      AGT_MODE="$mode"
    fi
  fi
}

load_config

usage() {
  cat <<EOF
agt — sandboxed AI agent development tool

Usage:
  agt start <branch> [prompt...]   Create worktree + sandbox, run Claude inside
  agt enter <branch>               Create worktree + sandbox, drop into a shell
  agt build [dockerfile]           Build container image (container mode only)
  agt list                         List running agt containers
  agt stop <branch>                Stop a running container
  agt clean <branch>               Remove worktree and container

Options:
  --image <name>                   Use a custom image (container mode, skips auto-build)
  --mode <container|sandbox>       Override execution mode

Execution modes (set via agt.toml):
  container                        Run inside an Apple container (default)
  sandbox                          Run via sandbox-exec (macOS seatbelt)

Config file (agt.toml) is loaded from ./agt.toml or ~/.config/agt/config.toml:
  [execution]
  mode = "sandbox"   # or "container"

Examples:
  agt start my-feature
  agt enter my-feature
  agt start my-feature --image my-custom-image
  agt build ./Dockerfile
  agt build --image my-tag ./path/to/Dockerfile

EOF
  exit 1
}

# --- helpers ---

git_root() {
  git rev-parse --show-toplevel 2>/dev/null || {
    red "Error: not inside a git repository"
    exit 1
  }
}

resolve_image() {
  local root
  root="$(git_root 2>/dev/null || true)"
  if [[ -n "$root" && -f "$root/Dockerfile.agt" ]]; then
    echo "$root/Dockerfile.agt"
  elif [[ -f "$AGT_DIR/Dockerfile" ]]; then
    echo "$AGT_DIR/Dockerfile"
  fi
}

image_exists() {
  container image list 2>/dev/null | grep -q "$1"
}

container_name() {
  echo "agt-${1//\//-}"
}

# --- sandbox-exec support ---

generate_sandbox_profile() {
  local worktree="$1"
  local git_root="${2:-}"
  local git_root_line=""
  local git_dir_line=""
  if [[ -n "$git_root" ]]; then
    git_root_line="  (subpath \"$git_root\")"
    git_dir_line="  (subpath \"$git_root/.git\")"
  fi
  cat <<SBEOF
(version 1)
(deny default)

;; Process, IPC, mach, and system calls — needed for shells and tools to function
(allow process*)
(allow signal)
(allow sysctl*)
(allow mach*)
(allow ipc*)
(allow file-ioctl)

;; Metadata and xattr reads must be unrestricted for path traversal
(allow file-read-metadata)
(allow file-read-xattr)

;; File content reads: system paths + worktree + git root + specific home dirs only
(allow file-read-data
  (literal "/")
  (subpath "/Applications")
  (subpath "/usr")
  (subpath "/bin")
  (subpath "/sbin")
  (subpath "/cores")
  (subpath "/home")
  (subpath "/Library")
  (subpath "/System")
  (subpath "/private")
  (subpath "/dev")
  (subpath "/opt")
  (subpath "/tmp")
  (subpath "/var")
  (subpath "/Volumes")
  (subpath "$worktree")
$git_root_line
  (regex #"^$HOME/\..*")
  (subpath "$HOME/Library"))

;; Writes: worktree, git dir, agt config, temp, and dev only
(allow file-write*
  (subpath "/dev")
  (subpath "/tmp")
  (subpath "/private/tmp")
  (subpath "/private/var/folders")
  (subpath "$worktree")
$git_dir_line
  (subpath "$HOME/.agt"))

;; Network and sockets
(allow network*)
(allow system-socket)
SBEOF
}

# Prepare worktree, mounts, auth, and image — sets shared variables
setup_env() {
  local image="$AGT_DEFAULT_IMAGE"

  # Parse flags, collect remaining args
  local -a remaining=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --image) image="$2"; shift 2 ;;
      --mode) AGT_MODE="$2"; _agt_mode_override=1; shift 2 ;;
      *) remaining+=("$1"); shift ;;
    esac
  done
  set -- "${remaining[@]}"

  local branch="$1"; shift || true

  # Export for caller
  _agt_image="$image"
  _agt_branch="$branch"
  _agt_remaining_args="$*"
  _agt_cname="$(container_name "$branch")"

  # Ensure image exists (container mode only)
  if [[ "$AGT_MODE" == "container" ]]; then
    if ! image_exists "$image"; then
      if [[ "$image" == "$AGT_DEFAULT_IMAGE" ]]; then
        local dockerfile
        dockerfile="$(resolve_image)"
        if [[ -n "$dockerfile" ]]; then
          yellow "Image not found, building from $dockerfile..."
          cmd_build "$image" "$dockerfile"
        else
          red "Error: no image '$image' found and no Dockerfile available to build one."
          red "Provide a Dockerfile.agt in your repo root, or run: agt build <dockerfile>"
          exit 1
        fi
      else
        red "Error: image '$image' not found. Build it first or check the name."
        exit 1
      fi
    fi
  fi

  # Set up working directory — git worktree if in a repo, plain dir otherwise
  local root
  root="$(git rev-parse --show-toplevel 2>/dev/null || true)"

  if [[ -n "$root" ]]; then
    _agt_worktree="$root/.worktrees/$branch"
    _agt_git_root="$root"
    _agt_git_dir="$root/.git"
    if [[ ! -d "$_agt_worktree" ]]; then
      bold "Creating worktree for branch '$branch'..."
      git -C "$root" worktree add "$_agt_worktree" -b "$branch" 2>/dev/null \
        || git -C "$root" worktree add "$_agt_worktree" "$branch"
      green "Worktree created at $_agt_worktree"
      # Persist the execution mode so subsequent commands remember it
      echo "$AGT_MODE" > "$_agt_worktree/.agt-mode"
    else
      yellow "Worktree already exists at $_agt_worktree"
      # Recall the mode used when this worktree was created (explicit --mode overrides)
      if [[ -n "${_agt_mode_override:-}" ]]; then
        echo "$AGT_MODE" > "$_agt_worktree/.agt-mode"
      elif [[ -f "$_agt_worktree/.agt-mode" ]]; then
        AGT_MODE="$(cat "$_agt_worktree/.agt-mode")"
      fi
    fi

    # Copy .env files (ignored by git) into worktree, preserving structure
    git -C "$root" ls-files --others --ignored --exclude-standard | grep '\.env' | while read -r relpath; do
      local destdir="$_agt_worktree/$(dirname "$relpath")"
      mkdir -p "$destdir"
      cp "$root/$relpath" "$destdir/"
    done
  else
    _agt_worktree="$PWD"
    bold "Using current directory as workspace"
  fi

  # Claude config — isolated copy, never writes back to host
  _agt_env=(-e "AGT_NAME=$_agt_cname")
  local agt_config_dir="$HOME/.agt/claude-config"
  mkdir -p "$agt_config_dir"

  if [[ -d "$HOME/.claude" ]]; then
    rsync -a --delete \
      --exclude '.credentials.json' \
      --exclude 'sessions' \
      --exclude 'history.jsonl' \
      --exclude 'todos' \
      --exclude 'statsig' \
      --exclude 'telemetry' \
      --exclude 'cache' \
      "$HOME/.claude/" "$agt_config_dir/"
  fi

  cp -f "$AGT_DIR/claude.json" "$agt_config_dir/.claude.json"

  if [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
    _agt_env+=(-e "ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY")
  else
    local creds_json
    creds_json="$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null || true)"
    if [[ -n "$creds_json" ]]; then
      echo "$creds_json" > "$agt_config_dir/.credentials.json"
      chmod 600 "$agt_config_dir/.credentials.json"
    else
      yellow "Warning: no API key or OAuth token found. Run 'claude' on the host to authenticate first."
    fi
  fi

  if [[ "$AGT_MODE" == "container" ]]; then
    # Shared cache directory across all agt containers
    local cache_dir="$HOME/.agt/cache"
    mkdir -p "$cache_dir"/{pnpm,npm,bun,mise}

    _agt_mounts=()
    _agt_mounts+=(-v "$cache_dir/pnpm:/cache/pnpm")
    _agt_mounts+=(-v "$cache_dir/npm:/cache/npm")
    _agt_mounts+=(-v "$cache_dir/bun:/cache/bun")
    _agt_mounts+=(-v "$cache_dir/mise:/cache/mise")
    _agt_env+=(-e "npm_config_store_dir=/cache/pnpm")
    _agt_env+=(-e "NPM_CONFIG_CACHE=/cache/npm")
    _agt_env+=(-e "BUN_INSTALL_CACHE_DIR=/cache/bun")
    _agt_env+=(-e "MISE_DATA_DIR=/cache/mise")

    _agt_mounts+=(-v "$agt_config_dir:$agt_config_dir")
    _agt_env+=(-e "CLAUDE_CONFIG_DIR=$agt_config_dir")
  else
    _agt_env+=("CLAUDE_CONFIG_DIR=$agt_config_dir")
  fi
}

container_state() {
  container ls --all --format json 2>/dev/null \
    | jq -r ".[] | select(.configuration.id == \"$1\") | .status" 2>/dev/null
}

ensure_container() {
  local state
  state="$(container_state "$_agt_cname")"

  if [[ -z "$state" ]]; then
    bold "Creating container $_agt_cname..."
    # Mount .git at the same host path so worktree .git file references resolve
    local -a git_mounts=()
    if [[ -n "${_agt_git_dir:-}" ]]; then
      git_mounts+=(-v "$_agt_git_dir:$_agt_git_dir")
    fi
    container run -d \
      --name "$_agt_cname" \
      --cpus "${AGT_CPUS:-4}" \
      --memory "${AGT_MEMORY:-4G}" \
      -v "$_agt_worktree:/work" \
      "${git_mounts[@]}" \
      "${_agt_mounts[@]}" \
      "${_agt_env[@]}" \
      -w /work \
      "$_agt_image" \
      sleep infinity
    green "Container $_agt_cname created"
  elif [[ "$state" == "stopped" ]]; then
    bold "Restarting container $_agt_cname..."
    container start "$_agt_cname"
    green "Container $_agt_cname restarted"
  else
    yellow "Container $_agt_cname already running"
  fi

  # Wait for container to be ready
  local retries=0
  while ! container exec "$_agt_cname" true 2>/dev/null; do
    (( retries++ >= 30 )) && { red "Container failed to become ready"; exit 1; }
    sleep 0.2
  done
}

exec_in_container() {
  container exec -it \
    -w /work \
    "${_agt_env[@]}" \
    "$_agt_cname" \
    "$@"
}

run_in_container() {
  ensure_container
  exec_in_container "$@"
}

run_in_sandbox() {
  local profile_file
  profile_file="$(mktemp /tmp/agt-sandbox.XXXXXX)"
  generate_sandbox_profile "$_agt_worktree" "${_agt_git_root:-}" > "$profile_file"

  bold "Starting sandbox for $_agt_branch in $_agt_worktree..."

  # Create a ZDOTDIR with a .zshrc that sources the user's and adds the prompt prefix
  local sandbox_zdotdir
  sandbox_zdotdir="$(mktemp -d /tmp/agt-sandbox-zd.XXXXXX)"
  cat > "$sandbox_zdotdir/.zshrc" <<'RCEOF'
[[ -f "$HOME/.zshrc" ]] && source "$HOME/.zshrc"
PROMPT="%F{yellow}[sandbox]%f $PROMPT"
RCEOF

  # Build env string — strip any "-e" flags (used by container mode)
  local -a env_args=(AGT_SANDBOX=1 "ZDOTDIR=$sandbox_zdotdir")
  for e in "${_agt_env[@]}"; do
    [[ "$e" == "-e" ]] && continue
    env_args+=("$e")
  done

  sandbox-exec -f "$profile_file" \
    /usr/bin/env "${env_args[@]}" \
    /bin/zsh -c "cd '$_agt_worktree' && exec \"\$@\"" -- "$@"

  rm -rf "$sandbox_zdotdir" "$profile_file"
}

run_agt() {
  if [[ "$AGT_MODE" == "sandbox" ]]; then
    run_in_sandbox "$@"
  else
    run_in_container "$@"
  fi
}

# --- commands ---

cmd_build() {
  local tag="$1"
  local dockerfile="$2"

  if [[ ! -f "$dockerfile" ]]; then
    red "Error: Dockerfile not found at $dockerfile"
    exit 1
  fi

  local context
  context="$(dirname "$dockerfile")"
  bold "Building $tag from $dockerfile..."
  container build --tag "$tag" --file "$dockerfile" "$context"
  green "Image $tag built successfully"
}

cmd_start() {
  setup_env "$@"
  local -a claude_args=(claude --dangerously-skip-permissions --channels plugin:telegram@claude-plugins-official)

  # Resume last session if one exists for this working directory
  local agt_config_dir="$HOME/.agt/claude-config"
  if [[ -d "$agt_config_dir/projects" ]] && find "$agt_config_dir/sessions" -name '*.json' -print -quit 2>/dev/null | grep -q .; then
    claude_args+=(--continue)
  fi

  if [[ -n "$_agt_remaining_args" ]]; then
    claude_args+=(-p "$_agt_remaining_args")
  fi
  run_agt "${claude_args[@]}"
}

cmd_enter() {
  setup_env "$@"
  run_agt zsh
}

cmd_list() {
  container ls --all 2>/dev/null | grep -E "^(ID|agt-)" || echo "No agt containers found"
}

cmd_stop() {
  local branch="$1"
  local cname
  cname="$(container_name "$branch")"
  bold "Stopping $cname..."
  container stop "$cname"
  green "Stopped $cname"
}

cmd_clean() {
  local branch="$1"
  local root
  root="$(git_root)"
  local worktree_dir="$root/.worktrees/$branch"
  local cname
  cname="$(container_name "$branch")"

  container stop "$cname" 2>/dev/null && yellow "Stopped container $cname"
  container rm "$cname" 2>/dev/null && yellow "Removed container $cname"

  if [[ -d "$worktree_dir" ]]; then
    git -C "$root" worktree remove "$worktree_dir" --force
    green "Removed worktree at $worktree_dir"
  fi

  green "Cleaned up $branch"
}

# --- main ---

[[ $# -lt 1 ]] && usage

case "$1" in
  start)
    [[ $# -lt 2 ]] && { red "Usage: agt start <branch> [prompt...]"; exit 1; }
    shift; cmd_start "$@"
    ;;
  enter)
    [[ $# -lt 2 ]] && { red "Usage: agt enter <branch>"; exit 1; }
    shift; cmd_enter "$@"
    ;;
  build)
    shift
    local build_tag="$AGT_DEFAULT_IMAGE"
    local build_file=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --image) build_tag="$2"; shift 2 ;;
        *) build_file="$1"; shift ;;
      esac
    done
    [[ -z "$build_file" ]] && build_file="$(resolve_image)"
    [[ -z "$build_file" ]] && { red "Usage: agt build [--image tag] <dockerfile>"; exit 1; }
    cmd_build "$build_tag" "$build_file"
    ;;
  list|ls)
    cmd_list
    ;;
  stop)
    [[ $# -lt 2 ]] && { red "Usage: agt stop <branch>"; exit 1; }
    cmd_stop "$2"
    ;;
  clean)
    [[ $# -lt 2 ]] && { red "Usage: agt clean <branch>"; exit 1; }
    cmd_clean "$2"
    ;;
  *)
    red "Unknown command: $1"
    usage
    ;;
esac
